PORT=3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# MongoDB connection string
# Local: mongodb://localhost:27017/cake_shop
# Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/cake_shop
MONGODB_URI=mongodb://localhost:27017/cake_shop

# Public URL for product share pages (/p/:id) — set on Render to your app URL
# Example: https://sweet-delights-api.onrender.com
PUBLIC_APP_URL=http://localhost:3000
